{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.vue",
    "lint:fix": "eslint src --ext .ts,.vue --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,css,scss}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,css,scss}\""
  },
  "dependencies": {
    "@arco-design/web-vue": "^2.58.0",
    "axios": "^1.18.1",
    "dayjs": "^1.11.21",
